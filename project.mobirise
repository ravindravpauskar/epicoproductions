              "src": "http://www.youtube.com/embed/sOSTC6FM6Bw"
            },
            "iconFont": {
              "class": "mbr-iconfont mbr-iconfont-features1",
              "link": "",
              "size": 0
            }
          },
          "title3": "<a href=\"https://www.epicop.com/\"><br></a><br><br><br><br><a href=\"https://www.epicop.com/\">Retail / Online Shopping Cart</a>",
          "caption3": "<b>Here's how to get<br> started in the business.</b>\n<br>Style strategy is about shopping smart!!\n<br>its all about how to shop for value without compromising to the style you wish for ,here we go to make it more easy for u.just at a one click",
          "button3": "<a data-app-btn=\"true\" href=\"https://mobirise.com\" class=\"mbr-buttons__btn btn btn-wrap btn-xs-lg btn-default\">LEARN MORE</a>",
          "media4": {
